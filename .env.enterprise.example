# InsightProfit Enterprise Configuration
# Copy to .env and fill in values

# Supabase (self-hosted on Oracle VPS)
SUPABASE_URL=https://supabase.insightprofit.live
SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_KEY=your_service_role_key_here

# Enterprise Endpoints
MISSION_CONTROL_URL=https://command.insightprofit.live
THEPOPEBOT_URL=https://bot.insightprofit.live
CLI_HUB_URL=https://clianything.cc

# Agent Identity (unique per platform)
AGENT_PLATFORM=omx
AGENT_NAME=omx-orchestrator
AGENT_DEPARTMENT=operations

# Token Tracking
ENABLE_TOKEN_TRACKING=true
TOKEN_LOG_LEVEL=detailed

# Knowledge Base
KB_AUTO_QUERY=true
KB_MAX_CONTEXT_ENTRIES=5